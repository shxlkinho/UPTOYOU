    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', sans-serif;
        }

        body {
            background-color: #080808;
            color: #fff;
            padding-bottom: 10px;
            padding-top: 70px;
        }

        /* Grid Layout */
        .grid-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 30px;
            max-width: 1300px;
            margin: 0 auto;
            padding: 40px 20px;
            margin-bottom: 20px;

        }

        /* Card Style */
        .card {
            background-color: #121212;
            border-radius: 28px;
            border: 3px solid;
            padding: 40px;
            display: flex;
            flex-direction: column;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .card:hover {
            transform: scale(1.03);
            background-color: #181818;
        }

        /* Gestione Icone Illustrate */
        .icon-wrapper {
            height: 140px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            justify-content: flex-start;
        }

        .icon-wrapper img {
            height: 100%;
            width: auto;
            object-fit: contain;
            filter: drop-shadow(0 10px 15px rgba(0,0,0,0.5));
        }

        /* Colori Bordi e Luci */
        .storia { border-color: #c48d5f; }
        .matematica { border-color:  #266ef3; }
        .scienze { border-color:#f8fc04; }
        .italiano { border-color: #ef4444; }
        .geografia { border-color: #3cee05; }
        .inglese { border-color: #5d34f1; }

        .card h2 {
            font-size: 2rem;
            margin-bottom: 15px;
            font-weight: 700;
        }

        .card p {
            color: #a0a0a0;
            font-size: 1.1rem;
            line-height: 1.5;
            margin-bottom: 30px;
            flex-grow: 1;
        }

        /* Pulsante Moderno */
        .btn {
            text-decoration: none;
            text-align: center;
            padding: 16px;
            border-radius: 18px;
            background-color: #1a1a1a;
            color: #fff;
            border: 1.5px solid #333;
            font-weight: 700;
            font-size: 1.1rem;
            transition: all 0.3s ease;
        }

        .btn:hover {
            background-color: #fff;
            color: #000;
            border-color: #fff;
            box-shadow: 0 10px 20px rgba(255,255,255,0.1);
        }
    </style>
</head>
